}]},{"cell_type":"markdown","source":["## 5 Continous Data Preparation - WoE"],"metadata":{"id":"Uz99QAOYvUWN"}},{"cell_type":"code","source":["df_inputs_prepr['term_int'].unique()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"WP4ZDfr-vVx1","executionInfo":{"status":"ok","timestamp":1768891221413,"user_tz":-540,"elapsed":8,"user":{"displayName":"Young Mark","userId":"08915244444976601721"}},"outputId":"5f8d5ac5-e188-49ab-d665-6024346e408d"},"execution_count":null,"outputs":[{"output_type":"execute_result","data":{"text/plain":["array([36, 60])"]},"metadata":{},"execution_count":60}]},{"cell_type":"code","source":["def woe_ordered_continuous(df_inputs, variable_name, df_targets, n_bins=10):\n","    # Combine inputs and targets for WoE calculation\n","    # Make a copy to avoid SettingWithCopyWarning if df_inputs is a slice\n","    df = pd.concat([df_inputs.copy(), df_targets.copy()], axis=1)\n","\n","    # Ensure variable is numeric\n","    df[variable_name] = pd.to_numeric(df[variable_name], errors='coerce')\n","    # Drop rows where variable_name or target_name is NaN after coercion to ensure clean calculation\n","    df.dropna(subset=[variable_name, df_targets.name], inplace=True)\n","\n","    # Check unique values. If few, treat as discrete.\n","    # Also handle the case where n_bins might be less than 2, which would cause issues with qcut\n","    if df[variable_name].nunique() <= n_bins or n_bins < 2:\n","        # Use unique values as bins, ensuring they are sorted for consistent WoE calculation\n","        bins = sorted(df[variable_name].unique())\n","        df['temp_bin'] = pd.Categorical(df[variable_name], categories=bins, ordered=True)\n","    else: # Bin continuous variable\n","        # Use qcut for binning, allow dropping duplicates if there aren't enough unique values for n_bins\n","        df['temp_bin'] = pd.qcut(df[variable_name], q=n_bins, duplicates='drop')\n","\n","    # Calculate counts of good and bad for each category (bin)\n","    # Using df_targets.name for the target column name\n","    df_temp = pd.DataFrame(df.groupby('temp_bin', observed=False)[df_targets.name].count())\n","    df_temp['good'] = df.groupby('temp_bin', observed=False)[df_targets.name].sum()\n","    df_temp['bad'] = df_temp[df_targets.name] - df_temp['good']\n","\n","    # Calculate overall good and bad counts\n","    overall_good = df_temp['good'].sum()\n","    overall_bad = df_temp['bad'].sum()\n","\n","    # Calculate proportions of good and bad for each category\n","    df_temp['good_prop'] = df_temp['good'] / overall_good\n","    df_temp['bad_prop'] = df_temp['bad'] / overall_bad\n","\n","    # Handle cases where proportions are zero by setting to a small positive value\n","    # This avoids issues with np.log(0) which results in -inf\n","    df_temp['good_prop'] = np.where(df_temp['good_prop'] == 0, 0.000001, df_temp['good_prop'])\n","    df_temp['bad_prop'] = np.where(df_temp['bad_prop'] == 0, 0.000001, df_temp['bad_prop'])\n","\n","    # Calculate WoE and IV\n","    df_temp['woe'] = np.log(df_temp['good_prop'] / df_temp['bad_prop'])\n","    df_temp['iv'] = (df_temp['good_prop'] - df_temp['bad_prop']) * df_temp['woe']\n","\n","    return df_temp.sort_values(by='woe')\n","\n","# Now call the function\n","df_temp = woe_ordered_continuous(df_inputs_prepr, 'term_int', df_targets_prepr)\n","df_temp"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":143},"id":"TXUiJu_GvaNN","executionInfo":{"status":"ok","timestamp":1768891222361,"user_tz":-540,"elapsed":950,"user":{"displayName":"Young Mark","userId":"08915244444976601721"}},"outputId":"1577d199-a797-47f5-fc2b-d0aaf9c17723"},"execution_count":null,"outputs":[{"output_type":"execute_result","data":{"text/plain":["          good_bad    good    bad  good_prop  bad_prop       woe        iv\n","temp_bin                                                                  \n","60          102570   88185  14385   0.264847  0.359068 -0.304361  0.028677\n