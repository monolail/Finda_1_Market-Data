policy=None,\n","              importance_type=None, interaction_constraints=None,\n","              learning_rate=0.05, max_bin=None, max_cat_threshold=None,\n","              max_cat_to_onehot=None, max_delta_step=None, max_depth=5,\n","              max_leaves=None, min_child_weight=None, missing=nan,\n","              monotone_constraints=None, multi_strategy=None, n_estimators=500,\n","              n_jobs=None, num_parallel_tree=None, ...)</pre></div> </div></div></div></div>"]},"metadata":{},"execution_count":13}]},{"cell_type":"markdown","source":["## 성능 평가"],"metadata":{"id":"1vCIjGwIs95B"}},{"cell_type":"code","source":["xgb_pred_proba = xgb_model.predict_proba(X_test)[:, 1]\n","print(\"XGBoost ROC-AUC:\", roc_auc_score(y_test, xgb_pred_proba))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"kLvET74YtBDJ","executionInfo":{"status":"ok","timestamp":1766988198775,"user_tz":-540,"elapsed":49,"user":{"displayName":"Young Mark","userId":"08915244444976601721"}},"outputId":"146f07d6-5afd-4a81-fe40-012a3b89e980"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["XGBoost ROC-AUC: 0.500196190340301\n"]}]},{"cell_type":"markdown","source":["## Confusion Matrix (Threshold = 0.5)"],"metadata":{"id":"DYf6KBNntF55"}},{"cell_type":"code","source":["threshold = 0.5\n","y_pred = (lgb_pred_proba > threshold).astype(int)\n","\n","cm = confusion_matrix(y_test, y_pred)\n","sns.heatmap(cm, annot=True, fmt=\"d\", cmap=\"Blues\")\n","plt.xlabel(\"Predicted\")\n","plt.ylabel(\"Actual\")\n","plt.title(\"LightGBM Confusion Matrix\")\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":472},"id":"IB_SvbLztHmR","executionInfo":{"status":"ok","timestamp":1766988225749,"user_tz":-540,"elapsed":332,"user":{"displayName":"Young Mark","userId":"08915244444976601721"}},"outputId":"727564c4-37c4-42f9-f6e3-eac559e3868a"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["## Feature Importance 비교"],"metadata":{"id":"_PAAZF9MtMdZ"}},{"cell_type":"code","source":["lgb_importance = pd.DataFrame({\n","    \"feature\": X.columns,\n","    \"importance\": lgb_model.feature_importances_\n","}).sort_values(by=\"importance\", ascending=False)\n","\n","sns.barplot(\n","    x=\"importance\",\n","    y=\"feature\",\n","    data=lgb_importance.head(10)\n",")\n","plt.title(\"LightGBM Feature Importance\")\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":472},"id":"NjEe-tVftOVI","executionInfo":{"status":"ok","timestamp":1766988253255,"user_tz":-540,"elapsed":277,"user":{"displayName":"Young Mark","userId":"08915244444976601721"}},"outputId":"3de52dce-848c-45e5-b2d8-4e06f6174491"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["## 금융 실무 포인트\n","- PAY_1, PAY_2 같은 연체 이력 변수가 항상 상위\n","- 지나치게 강한 변수 → 정책 변경 시 모델 붕괴 위험"],"metadata":{"id":"pbaVdd4ktTbv"}},{"cell_type":"markdown","source":["## Core Message\n","- 금융 예측은 모델 성능보다 문제 정의가 70%\n","- 회귀 vs 분류 선택은 비즈니스 의사결정 구조에 달림\n","- 파이프라인을 표준화해야 감사·모델 리스크 관리(MRM) 대응 가능"],"metadata":{"id":"cHE1YxE4tajv"}}]}