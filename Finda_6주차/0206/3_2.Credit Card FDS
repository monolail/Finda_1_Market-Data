in_scores_mean, 'o-', color=\"#ff9124\",\n","             label=\"Training score\")\n","    ax2.plot(train_sizes, test_scores_mean, 'o-', color=\"#2492ff\",\n","             label=\"Cross-validation score\")\n","    ax2.set_title(\"Knears Neighbors Learning Curve\", fontsize=14)\n","    ax2.set_xlabel('Training size (m)')\n","    ax2.set_ylabel('Score')\n","    ax2.grid(True)\n","    ax2.legend(loc=\"best\")\n","\n","    # Third Estimator\n","    train_sizes, train_scores, test_scores = learning_curve(\n","        estimator3, X, y, cv=cv, n_jobs=n_jobs, train_sizes=train_sizes)\n","    train_scores_mean = np.mean(train_scores, axis=1)\n","    train_scores_std = np.std(train_scores, axis=1)\n","    test_scores_mean = np.mean(test_scores, axis=1)\n","    test_scores_std = np.std(test_scores, axis=1)\n","    ax3.fill_between(train_sizes, train_scores_mean - train_scores_std,\n","                     train_scores_mean + train_scores_std, alpha=0.1,\n","                     color=\"#ff9124\")\n","    ax3.fill_between(train_sizes, test_scores_mean - test_scores_std,\n","                     test_scores_mean + test_scores_std, alpha=0.1, color=\"#2492ff\")\n","    ax3.plot(train_sizes, train_scores_mean, 'o-', color=\"#ff9124\",\n","             label=\"Training score\")\n","    ax3.plot(train_sizes, test_scores_mean, 'o-', color=\"#2492ff\",\n","             label=\"Cross-validation score\")\n","    ax3.set_title(\"Support Vector Classifier \\n Learning Curve\", fontsize=14)\n","    ax3.set_xlabel('Training size (m)')\n","    ax3.set_ylabel('Score')\n","    ax3.grid(True)\n","    ax3.legend(loc=\"best\")\n","\n","    # Fourth Estimator\n","    train_sizes, train_scores, test_scores = learning_curve(\n","        estimator4, X, y, cv=cv, n_jobs=n_jobs, train_sizes=train_sizes)\n","    train_scores_mean = np.mean(train_scores, axis=1)\n","    train_scores_std = np.std(train_scores, axis=1)\n","    test_scores_mean = np.mean(test_scores, axis=1)\n","    test_scores_std = np.std(test_scores, axis=1)\n","    ax4.fill_between(train_sizes, train_scores_mean - train_scores_std,\n","                     train_scores_mean + train_scores_std, alpha=0.1,\n","                     color=\"#ff9124\")\n","    ax4.fill_between(train_sizes, test_scores_mean - test_scores_std,\n","                     test_scores_mean + test_scores_std, alpha=0.1, color=\"#2492ff\")\n","    ax4.plot(train_sizes, train_scores_mean, 'o-', color=\"#ff9124\",\n","             label=\"Training score\")\n","    ax4.plot(train_sizes, test_scores_mean, 'o-', color=\"#2492ff\",\n","             label=\"Cross-validation score\")\n","    ax4.set_title(\"Decision Tree Classifier \\n Learning Curve\", fontsize=14)\n","    ax4.set_xlabel('Training size (m)')\n","    ax4.set_ylabel('Score')\n","    ax4.grid(True)\n","    ax4.legend(loc=\"best\")\n","    return plt"],"execution_count":49,"outputs":[]},{"cell_type":"markdown","source":["## 📈 학습 곡선(Learning Curve) 분석\n","\n","학습 곡선은 모델의 **편향(Bias)**과 **분산(Variance)** 문제를 진단하는 강력한 도구입니다. 훈련 세트의 크기를 점진적으로 늘려가며 훈련 점수와 교차 검증 점수의 차이를 비교합니다.\n","\n","### 1. 학습 곡선을 그리는 이유\n","\n","모델의 성능이 좋지 않을 때, 더 많은 데이터를 수집해야 하는지 아니면 모델의 복잡도를 조절해야 하는지 판단하는 기준이 됩니다.\n","\n","* **과적합(High Variance):** 훈련 점수는 높지만 교차 검증 점수가 훨씬 낮을 때 발생합니다. 두 곡선 사이의 간격(Gap)이 큽니다.\n","* **과소적합(High Bias):** 훈련 점수와 교차 검증 점수가 모두 낮을 때 발생합니다. 데이터를 더 추가해도 성능이 나아지지 않는 경우가 많습니다.\n","\n","### 2. 코드 구조 및 주요 구성 요소\n","\n","이 함수는 `Logistic Regression`, `KNN`, `SVC`, `Decision Tree` 네 가지 모델의 학습 곡선을 2x2 격자 형태로 출력합니다.\n","\n","* **`learning_curve()`:** 훈련 데이터의 크기를 바꿔가며 모델을 재학습하고 점수를 계산합니다.\n","* **`fill_between()`:** 점수의 표준편차(std) 범위를 색칠하여 성능의 변동성(안정성)을 시각화합니다.\n","* **두 개의 선:**\n","* **주황색 선 (Training score):** 훈련 데이터로 얻은 점수입니다.\n","* **파란색 선 (Cross-validation score):** 검증 데이터로 얻은 점수(모델의 실제 성능)입니다.\n","\n","\n","\n","### 3. 그래프 해석 가이드\n","\n","* **두 선이 만나는 지점:** 훈련 데이터 양이 증가함에 따라 두 선이 서로 가까워지며 높은 점수에서 수렴한다면, 모델이 데이터를 아주 잘 학습했다는 뜻입니다.\n","* **훈련 점수가 계속 높은 경우:** 모델이 훈련 데이터를 거의 암기하고 있을 가능성(과적합)이 있으므로 검증 점수와의 간격을 확인해야 합니다.\n","* **검증 점수가 정체되는 경우:** 데이터가 더 많아져도 이 모델 구조로는 더 이상의 성능 향상이 어렵다는 것을 의미합니다.\n","\n","### 4. 주요 파라미터\n","\n","* `cv`: 데이터를 나누는 교차 검증 전략(보통 `ShuffleSplit` 사용).\n","* `train_sizes`: 훈련 세트의 비율(10%부터 100%까지 5단계로 설정).\n","* `n_jobs`: 계산 속도를 높이기 위해 사용하는 CPU 코어 수."],"metadata":{"id":"W7qXhsrrqDWi"}},{"cell_type":"code","metadata":{"id":"bAsblMm0eEbw","colab":{"base_uri":"https://localhost:8080/","height":593},"outputId":"c68c0d1d-995e-4b82-a61d-0a0a099c46ea","executionInfo":{"status":"ok","timestamp":1770193562986,"user_tz":-540,"elapsed":32657,"user":{"displayName":"Young Mark","userId":"08915244444976601721"}}},"source":["cv = ShuffleSplit(n_splits=100, test_size=0.2, random_state=42)\n","plot_learning_curve(log_reg, knears_neighbors, svc, tree_clf, X_train, y_train, (0.87, 1.01), cv=cv, n_jobs=4)"],"execution_count":50,"outputs":[{"output_type":"execute_result","data":{"text/plain":["<module 'matplotlib.pyplot' from '/usr/local/lib/python3.12/dist-packages/matplotlib/pyplot.py'>"]},"metadata":{},"execution_count":50},{"output_type":"display_data","data":{"text/plain":["<Figure size 2000x1400 with 4 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","metadata":{"id":"uoXA-7PveMwr","executionInfo":{"status":"ok","timestamp":1770193563873,"user_tz":-540,"elapsed":867,"user":{"displayName":"Young Mark","userId":"08915244444976601721"}}},"source":["from sklearn.metrics import roc_curve\n","from sklearn.model_selection import cross_val_predict\n","# Create a DataFrame with all the scores and the classifiers names.\n","\n","log_reg_pred = cross_val_predict(log_reg, X_train, y_train, cv=5,\n","                             method=\"decision_function\")\n","\n","knears_pred = cross_val_predict(knears_neighbors, X_train, y_train, cv=5)\n","\n","svc_pred = cross_val_predict(svc, X_train, y_train, cv=5,\n","                             method=\"decision_function\")\n","\n","tree_pred = cross_val_predict(tree_clf, X_train, y_train, cv=5)"],"execution_count":51,"outputs":[]},{"cell_type":"code","metadata":{"id":"IGb36bUVePYS","colab":{"base_uri":"https://localhost:8080/"},"outputId":"c2aba0b2-a5cd-45db-bf6a-3c46ad0fed9e","executionInfo":{"status":"ok","timestamp":1770193563937,"user_tz":-540,"elapsed":45,"user":{"displayName":"Young Mark","userId":"08915244444976601721"}}},"source":["from sklearn.metrics import roc_auc_score\n","\n","print('Logistic Regression: ', roc_auc_score(y_train, log_reg_pred))\n","print('KNears Neighbors: ', roc_auc_score(y_train, knears_pred))\n","print('Support Vector Classifier: ', roc_auc_score(y_train, svc_pred))\n","print('Decision Tree Classifier: ', roc_auc_score(y_train, tree_pred))"],"execution_count":52,"outputs":[{"output_type":"stream","name":"stdout","text":["Logistic Regression:  0.9825666538205514\n","KNears Neighbors:  0.9292225764635812\n","Support Vector Classifier:  0.977808919875276\n","Decision Tree Classifier:  0.9151560802998984\n"]}]},{"cell_type":"code","metadata":{"id":"M3dwQLLfeT3a","colab":{"base_uri":"https://localhost:8080/","height":438},"outputId":"17aa179d-7325-478d-d2d9-d0f0649e5ca2","executionInfo":{"status":"ok","timestamp":1770193565025,"user_tz":-540,"elapsed":1086,"user":{"displayName":"Young Mark","userId":"08915244444976601721"}}},"source":["log_fpr, log_tpr, log_thresold = roc_curve(y_train, log_reg_pred)\n","knear_fpr, knear_tpr, knear_threshold = roc_curve(y_train, knears_pred)\n","svc_fpr, svc_tpr, svc_threshold = roc_curve(y_train, svc_pred)\n","tree_fpr, tree_tpr, tree_threshold = roc_curve(y_train, tree_pred)\n","\n","\n","def graph_roc_curve_multiple(log_fpr, log_tpr, knear_fpr, knear_tpr, svc_fpr, svc_tpr, tree_fpr, tree_tpr):\n","    plt.figure(figsize=(16,8))\n","    plt.title('ROC Curve \\n Top 4 Classifiers', fontsize=18)\n","    plt.plot(log_fpr, log_tpr, label='Logistic Regression Classifier Score: {:.4f}'.format(roc_auc_score(y_train, log_reg_pred)))\n","    plt.plot(knear_fpr, knear_tpr, label='KNears Neighbors Classifier Score: {:.4f}'.format(roc_auc_score(y_train, knears_pred)))\n","    plt.plot(svc_fpr, svc_tpr, label='Support Vector Classifier Score: {:.4f}'.format(roc_auc_score(y_train, svc_pred)))\n","    plt.plot(tree_fpr, tree_tpr, label='Decision Tree Classifier Score: {:.4f}'.format(roc_auc_score(y_train, tree_pred)))\n","    plt.plot([0, 1], [0, 1], 'k--')\n","    plt.axis([-0.01, 1, 0, 1])\n","    plt.xlabel('False Positive Rate', fontsize=16)\n","    plt.ylabel('True Positive Rate', fontsize=16)\n","    plt.annotate('Minimum ROC Score of 50% \\n (This is the minimum score to get)', xy=(0.5, 0.5), xytext=(0.6, 0.3),\n","                arrowprops=dict(facecolor='#6E726D', shrink=0.05),\n","                )\n","    plt.legend()\n","\n","graph_roc_curve_multiple(log_fpr, log_tpr, knear_fpr, knear_tpr, svc_fpr, svc_tpr, tree_fpr, tree_tpr)\n","plt.show()"],"execution_count":53,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1600x800 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["## 📈 ROC Curve 및 AUC Score 분석\n","\n","모델의 성능을 단순히 '정확도(Accuracy)'로만 판단하는 것은 위험할 수 있습니다. 특히 이 프로젝트와 같은 불균형 데이터셋에서는 **ROC Curve**를 통해 모델이 얼마나 '사기 거래(Positive)'와 '정상 거래(Negative)'를 잘 구분하는지 시각화하는 것이 중요합니다.\n","\n","### 1. ROC Curve란?\n","\n","* **X축 (False Positive Rate, FPR):** 실제로는 정상인데 사기라고 잘못 예측한 비율 ()\n","* **Y축 (True Positive Rate, TPR):** 실제 사기를 사기라고 정확히 맞춘 비율 ()\n","* **해석:** 그래프가 왼쪽 상단 모서리에 가까울수록(즉, FPR은 낮고 TPR은 높을수록) 성능이 뛰어난 모델입니다.\n","\n","### 2. AUC (Area Under the Curve) Score\n","\n","* ROC 곡선 아래의 면적을 의미하며, **1.0에 가까울수록 완벽한 모델**입니다.\n","* **0.5 (대각선 점선):** 아무런 학습 없이 무작위로 찍는 수준(Random Guess)을 의미합니다. 코드 내 `Minimum ROC Score of 50%` 주석이 이 지점을 가리킵니다.\n","\n","### 3. 코드 구성 분석\n","\n","* **`roc_curve()`**: 각 모델의 FPR, TPR 값을 계산하여 곡선을 그릴 좌표를 생성합니다.\n","* **`graph_roc_curve_multiple()`**:\n","* 4개의 모델(Logistic Regression, KNN, SVC, Decision Tree)을 하나의 그래프에 겹쳐 그려 **성능을 한눈에 비교**합니다.\n","* 각 모델의 범례(Legend)에 **AUC Score**를 소수점 4자리까지 표시하여 정량적 비교를 돕습니다.\n","\n","\n","* **`plt.plot([0, 1], [0, 1], 'k--')`**: 기준점이 되는 50% 확률의 대각 점선을 그립니다.\n","\n","### 4. 결과 해석 포인트\n","\n","1. **가장 높은 곡선:** 그래프에서 가장 위쪽에 위치한 곡선이 현재 데이터셋에서 가장 우수한 분류 성능을 보이는 모델입니다.\n","2. **곡선의 기울기:** 초기 FPR이 낮을 때 TPR이 얼마나 빠르게 상승하는지를 통해 모델의 사기 탐지 효율성을 알 수 있습니다.\n","3. **모델 선정:** AUC Score가 가장 높은 모델을 최종 모델로 선택하거나, 비즈니스 목적(사기를 절대 놓치면 안 되는지 등)에 따라 임계값을 조정하는 근거로 삼습니다."],"metadata":{"id":"0ss1-fQ_qVnc"}},{"cell_type":"markdown","metadata":{"id":"GGFIf0-2eZH6"},"source":["A Deeper Look into LogisticRegression:\n","In this section we will ive a deeper look into the logistic regression classifier.\n","\n","Terms:\n","\n","* True Positives: Correctly Classified Fraud Transactions\n","* False Positives: Incorrectly Classified Fraud Transactions\n","* True Negative: Correctly Classified Non-Fraud Transactions\n","* False Negative: Incorrectly Classified Non-Fraud Transactions\n","* Precision: True Positives/(True Positives + False Positives)\n","* Recall: True Positives/(True Positives + False Negatives)\n","* Precision as the name says, says how precise (how sure) is our model in detecting fraud transactions while recall is the amount of fraud cases our model is able to detect.\n","* Precision/Recall Tradeoff: The more precise (selective) our model is, the less cases it will detect. Example: Assuming that our model has a precision of 95%, Let's say there are only 5 fraud cases in which the model is 95% precise or more that these are fraud cases. Then let's say there are 5 more cases that our model considers 90% to be a fraud case, if we lower the precision there are more cases that our model will be able to detect.\n","\n","### Summary:\n","\n","* Precision starts to descend between 0.90 and 0.92 nevertheless, our precision score is still pretty high and still we have a descent recall score."]},{"cell_type":"code","metadata":{"id":"CGnRPfnverfB","colab":{"base_uri":"https://localhost:8080/","height":544},"outputId":"a58772c2-479a-4214-9b0f-7881df6b9a48","executionInfo":{"status":"ok","timestamp":1770193565392,"user_tz":-540,"elapsed":366,"user":{"displayName":"Young Mark","userId":"08915244444976601721"}}},"source":["def logistic_roc_curve(log_fpr, log_tpr):\n","    plt.figure(figsize=(12,8))\n","    plt.title('Logistic Regression ROC Curve', fontsize=16)\n","    plt.plot(log_fpr, log_tpr, 'b-', linewidth=2)\n","    plt.plot([0, 1], [0, 1], 'r--')\n","    plt.xlabel('False Positive Rate', fontsize=16)\n","    plt.ylabel('True Positive Rate', fontsize=16)\n","    plt.axis([-0.01,1,0,1])\n","\n","\n","logistic_roc_curve(log_fpr, log_tpr)\n","plt.show()"],"execution_count":54,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x800 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","metadata":{"id":"EZG7sQuPewDs","executionInfo":{"status":"ok","timestamp":1770193565431,"user_tz":-540,"elapsed":37,"user":{"displayName":"Young Mark","userId":"08915244444976601721"}}},"source":["from sklearn.metrics import precision_recall_curve\n","\n","precision, recall, threshold = precision_recall_curve(y_train, log_reg_pred)"],"execution_count":55,"outputs":[]},{"cell_type":"code","metadata":{"id":"X_a72VupewQi","colab":{"base_uri":"https://localhost:8080/"},"outputId":"266db468-b9c2-4ae0-84f9-93e8623fa115","executionInfo":{"status":"ok","timestamp":1770193565471,"user_tz":-540,"elapsed":38,"user":{"displayName":"Young Mark","userId":"08915244444976601721"}}},"source":["from sklearn.metrics import recall_score, precision_score, f1_score, accuracy_score\n","y_pred = log_reg.predict(X_train)\n","\n","# Overfitting Case\n","print('---' * 45)\n","print('Overfitting: \\n')\n","print('Recall Score: {:.2f}'.format(recall_score(y_train, y_pred)))\n","print('Precision Score: {:.2f}'.format(precision_score(y_train, y_pred)))\n","print('F1 Score: {:.2f}'.format(f1_score(y_train, y_pred)))\n","print('Accuracy Score: {:.2f}'.format(accuracy_score(y_train, y_pred)))\n","print('---' * 45)"],"execution_count":56,"outputs":[{"output_type":"stream","name":"stdout","text":["---------------------------------------------------------------------------------------------------------------------------------------\n","Overfitting: \n","\n","Recall Score: 0.92\n","Precision Score: 0.98\n","F1 Score: 0.95\n","Accuracy Score: 0.95\n","---------------------------------------------------------------------------------------------------------------------------------------\n"]}]},{"cell_type":"markdown","metadata":{"id":"ypZkVqqsWboo"},"source":["예측값을 실제 부정거래여부 칼럼인 Class와 비교하여 성능을 살펴보겠습니다.\n","측정 지표로는 Accuracy(정확도), Recall(재현율), Precision(정밀도), F1-score 입니다.\n","\n","금융 거래에서는 정확도도 물론 중요하지만, 실제 부정거래를 부정거래로 예측하는 비율인 Recall(재현율) 값이 중요하게 여겨집니다."]},{"cell_type":"code","metadata":{"id":"wSa3hRNPWeNu","colab":{"base_uri":"https://localhost:8080/","height":702},"outputId":"102d0282-33aa-42a2-c341-bdd5b7b0b369","executionInfo":{"status":"ok","timestamp":1770193566463,"user_tz":-540,"elapsed":971,"user":{"displayName":"Young Mark","userId":"08915244444976601721"}}},"source":["from sklearn.metrics import confusion_matrix, classification_report, accuracy_score\n","import itertools\n","import numpy as np\n","import matplotlib.pyplot as plt\n","from sklearn.ensemble import IsolationForest\n","\n","# Redefine X and y to ensure they are available in this cell's scope\n","X = new_df.drop('Class', axis=1)\n","y = new_df['Class']\n","\n","class_name = [0, 1]\n","def plot_confusion_matrix(classes, pred, y_test,\n","                          normalize=False, title='Confusion matrix', cmap=plt.cm.Blues):\n","\n","    cm = confusion_matrix(y_test, pred)\n","    plt.imshow(cm, interpolation='nearest', cmap=cmap)\n","    plt.title(title)\n","    plt.colorbar()\n","    tick_marks = np.arange(len(classes))\n","    plt.xticks(tick_marks, classes, rotation=0)\n","    plt.yticks(tick_marks, classes)\n","\n","    if normalize:\n","        cm = cm.astype('float') / cm.sum(axis=1)[:, np.newaxis]\n","    thresh = cm.max() / 2.\n","    for i, j in itertools.product(range(cm.shape[0]), range(cm.shape[1])):\n","        plt.text(j, i, cm[i, j],\n","                 horizontalalignment=\"center\",\n","                 color=\"white\" if cm[i, j] > thresh else \"black\")\n","\n","# Implement Isolation Forest and generate pred_outlier\n","# 'contamination' is set to 0.5 as the new_df has an equal distribution of fraud and non-fraud.\n","# 'X' and 'y' are already defined from new_df in cell p-XbRgercfzI.\n","isolation_forest = IsolationForest(n_estimators=100, contamination=0.5, random_state=42)\n","isolation_forest.fit(X)\n","outlier_predictions = isolation_forest.predict(X)\n","\n","# Convert Isolation Forest predictions (-1 for outlier/fraud, 1 for inlier/non-fraud)\n","# to match the 'Class' labels (1 for fraud, 0 for non-fraud)\n","pred_outlier = np.where(outlier_predictions == -1, 1, 0)\n","\n","# 평가\n","print('confusion matrix\\n', confusion_matrix(pred_outlier, y))\n","print('Accuracy: ',accuracy_score(pred_outlier, y))\n","print('classification_report\\n', classification_report(pred_outlier, y))\n","plot_confusion_matrix(class_name, pred_outlier, y, title='Isolation Forest')"],"execution_count":57,"outputs":[{"output_type":"stream","name":"stdout","text":["confusion matrix\n"," [[381  92]\n"," [108 365]]\n","Accuracy:  0.7885835095137421\n","classification_report\n","               precision    recall  f1-score   support\n","\n","           0       0.78      0.81      0.79       473\n","           1       0.80      0.77      0.78       473\n","\n","    accuracy                           0.79       946\n","   macro avg       0.79      0.79      0.79       946\n","weighted avg       0.79      0.79      0.79       946\n","\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]}]}